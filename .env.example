# Copy to .env and replace every placeholder before running Compose.

APP_ENV=local
APP_SECRET_KEY=<replace-with-strong-random-secret-at-least-32-chars>
DATABASE_URL=postgresql+psycopg://can:can@host.docker.internal:5402/can
DATABASE_SCHEMA=can_tracker
PII_ENCRYPTION_KEY=<replace-with-pii-encryption-secret-at-least-32-chars>
PII_SEARCH_HASH_KEY=<replace-with-pii-search-hash-secret-at-least-32-chars>
SESSION_COOKIE_NAME=can_tracker_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=28800
CORS_ORIGINS=http://127.0.0.1:3001,http://localhost:3001
LOG_LEVEL=INFO
BACKUP_RETENTION_DAYS=14

POSTGRES_DB=can
POSTGRES_USER=can
POSTGRES_PASSWORD=can

API_BIND=127.0.0.1
API_PORT=8001
FORWARDED_ALLOW_IPS=127.0.0.1
API_IMAGE=can-tracker-service:latest

UI_BIND=127.0.0.1
UI_PORT=3001
UI_IMAGE=can-tracker-frontend:latest
API_UPSTREAM=http://host.docker.internal:8001

BOOTSTRAP_ADMIN_NAME=<replace-with-first-admin-name>
BOOTSTRAP_ADMIN_EMAIL=<replace-with-first-admin-email>
BOOTSTRAP_ADMIN_PASSWORD=<replace-with-temporary-first-admin-password>
