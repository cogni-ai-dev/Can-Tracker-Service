# Copy to .env and replace every placeholder before running production Compose.

APP_ENV=production
APP_SECRET_KEY=<replace-with-strong-random-secret-at-least-32-chars>
DATABASE_URL=postgresql+psycopg://<postgres-user>:<postgres-password>@postgres:5432/<postgres-db>
PII_ENCRYPTION_KEY=<replace-with-pii-encryption-secret-at-least-32-chars>
PII_SEARCH_HASH_KEY=<replace-with-pii-search-hash-secret-at-least-32-chars>
SESSION_COOKIE_NAME=<replace-with-cookie-name>
SESSION_COOKIE_SECURE=true
SESSION_TTL_SECONDS=28800
CORS_ORIGINS=https://<your-production-domain>
LOG_LEVEL=INFO
BACKUP_RETENTION_DAYS=14

POSTGRES_DB=<replace-with-postgres-db>
POSTGRES_USER=<replace-with-postgres-user>
POSTGRES_PASSWORD=<replace-with-postgres-password>

API_BIND=127.0.0.1
API_PORT=8000
FORWARDED_ALLOW_IPS=127.0.0.1
API_IMAGE=can-tracker-service:latest

BOOTSTRAP_ADMIN_NAME=<replace-with-first-admin-name>
BOOTSTRAP_ADMIN_EMAIL=<replace-with-first-admin-email>
BOOTSTRAP_ADMIN_PASSWORD=<replace-with-temporary-first-admin-password>
